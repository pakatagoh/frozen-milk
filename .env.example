# Copy to .env (gitignored) and fill in real values.
# Never commit secrets — this file only documents the required keys.
#
# ── Docker Compose quick-start ─────────────────────────────────
#   1. ./scripts/generate-imgproxy-keys.sh     (generates keys into .env)
#   2. docker compose up -d                    (full stack: nginx + app + imgproxy)
#   3. open http://localhost:3000
#
#   For hot-reload dev (app on host, imgproxy in Docker):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   pnpm dev
#
# ────────────────────────────────────────────────────────────────

# Google Sheets integration (src/lib/sheets.ts)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=
GOOGLE_TOKEN_PATH=./google-token.json

# Vision model API (src/lib/ai.ts)
OPENCODE_API_KEY=

# Image storage + imgproxy signing (src/lib/images.ts)
# Local dev: ./data/images/originals  |  Docker: /images/originals (set in compose)
IMAGE_ORIGINALS_DIR=./data/images/originals
# imgproxy base URL — nginx routes /img → imgproxy (single-origin, no CORS issues)
IMGPROXY_BASE_URL=http://localhost:3000/img
# Generate with: ./scripts/generate-imgproxy-keys.sh
IMGPROXY_KEY=
IMGPROXY_SALT=
